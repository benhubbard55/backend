<% block('title', 'Show City' ); %>
    <style>
        .jumbotron {
            background: rgb(63, 29, 94);
            background: radial-gradient(circle,
                    rgba(63, 29, 94, 1) 0%,
                    rgba(13, 12, 13, 1) 98%);
            margin: 0;
            height: 100vh;
            border-radius: 0;
            display: flex;
            align-items: center;
            flex-direction: column;
            justify-content: center;
        }

        .display-4 {
            color: white;
        }

        p {
            color: white;
        }

        .notification {
            width: 500px;
            padding: 15px;
            margin: 10px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            background-color: white;
        }

        .notification .icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            margin-right: 15px;
        }

        .notification .icon-success {
            background-color: #4caf50;
            color: white;
        }

        .notification .icon-error {
            background-color: #f44336;
            color: white;
        }

        .notification .data {
            flex-grow: 1;
        }

        .notification .data h4 {
            margin: 0;
            font-size: 16px;
            font-weight: bold;
        }

        .notification .data p {
            margin: 5px 0 0 0;
            font-size: 14px;
            color: #555;
        }

        .notification .close {
            font-size: 16px;
            color: #aaa;
            cursor: pointer;
        }

        .notification-success {
            border-left: 4px solid #4caf50;
        }

        .notification-error {
            border-left: 4px solid #f44336;
        }

        @media (max-width: 640px) {
            .notification {
                width: 350px;
                padding: 8px;
            }
        }

        @media (max-width: 350px) {
            .notification {
                width: 330px;
                padding: 8px;
            }
        }
    </style>
    <div class="">
        <div class="jumbotron">
            <h1 class="display-4">Hello, <%= name %>!</h1>
            <hr class="my-4" />

            <% if (success) { %>
                <div class="notification notification-success">
                    <div class="icon icon-success">✔</div>
                    <div class="data">
                        <h4>Congratulations!</h4>
                        <p>
                            <%= message %>
                        </p>
                    </div>
                </div>
                <% } else { %>
                    <div class="notification notification-error">
                        <div class="icon icon-error">⚠</div>
                        <div class="data">
                            <h4>Oh no!</h4>
                            <p>
                                <%= message %>
                            </p>
                        </div>
                    </div>
                    <% } %>
        </div>
    </div>