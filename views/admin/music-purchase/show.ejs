<% block('title', 'Details Music' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Music</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="/admin/music">Musics</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Details</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Music Details <small></small></h5>
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">First Name</label>
                                    <div class="col-sm-10 col-form-label">
                                        <%= musicRecord.title %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Genre Type</label>
                                    <div class="col-sm-10 col-form-label">
                                        <%= musicRecord.musicTypeId?.genreName %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Description</label>
                                    <div class="col-sm-10 col-form-label">
                                        <%= musicRecord.description %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Artists name</label>
                                    <div class="col-sm-10 col-form-label">
                                        <a href="/admin/artist/show/<%= musicRecord?.userId?.id %>" class="href">
                                            <%= musicRecord?.userId?.name %>
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Music Free/Paid</label>
                                    <div class="col-sm-10 col-form-label">
                                        <% if (musicRecord?.isPremium) { %>
                                            <div>Paid</div>
                                            <% } else { %>
                                                <div>Free</div>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Amount</label>
                                    <div class="col-sm-10 col-form-label">
                                        <%= musicRecord?.amount %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Music</label>
                                    <div class="col-sm-10 col-form-label">
                                        <audio controls>
                                            <source src="<%= musicRecord?.musicFileName %>" type="audio/mpeg">
                                        </audio>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group row">
                                    <label class="col-sm-2 col-form-label">Music Profile</label>
                                    <div class="col-sm-10 col-form-label">
                                        <div style="height: 150px; width: 150px;">
                                            <img src="<%= musicRecord?.profileImage %>"
                                                onerror="this.src='https://placehold.co/150x150?text=Profile&font=roboto'"
                                                style="height: 100%; width: 100%;" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>