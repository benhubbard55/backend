<% if (userRecord && userRecord.id) { %>
    <form id="userForm" method="POST" action="/admin/music-type/update/<%= userRecord.id %>">
        <% } else { %>
            <form id="userForm" method="POST" action="/admin/music-type/create">
                <% } %>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">Genre</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" name="genreName"
                                value="<%= userRecord.genreName || '' %>">
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">Active</label>
                        <div class="col-sm-10">
                            <!-- Dynamic hidden input based on userRecord.isActive -->
                            <input type="hidden" id="isActive" name="isActive"
                                value="<%= userRecord.isActive ? 'true' : 'false' %>">
                            <div class="custom-control custom-switch">
                                <input type="checkbox" class="custom-control-input" id="isActiveSwitch"
                                    onchange="onChange()" <% if (userRecord.isActive) { %> checked <% } %> >
                                    <label class="custom-control-label" for="isActiveSwitch"></label>
                            </div>
                        </div>
                    </div>

                    <div class="hr-line-dashed"></div>
                    <div class="form-group row">
                        <div class="col-sm-4 col-sm-offset-2">
                            <a href="/admin/music-type" class="btn btn-white btn-sm">Cancel</a>
                            <button class="btn btn-primary btn-sm" type="submit">Save changes</button>
                        </div>
                    </div>
            </form>

            <% if(req.session.flash) { %>
                <script type="text/javascript">
                    $(document).ready(function () {
                        toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
                    });
                </script>
                <% req.session.flash={}; %>
                    <% } %>

                        <script>

                            function onChange(params) {
                                const val = document.getElementById("isActiveSwitch").checked
                                document.getElementById("isActive").value = val
                            }

                            $(document).ready(function () {
                                $("#role").select2({ multiple: true, placeholder: "Select Role" });

                                var validator = $("#userForm").validate({
                                    rules: {
                                        genreName: { required: true },
                                        lastName: { required: true },
                                    },
                                    messages: {
                                        genreName: { required: "Genre is required" },
                                        lastName: { required: "Active is required" },
                                    },
                                });
                            });
                        </script>