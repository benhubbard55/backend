<% block('title', 'Music Type' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Music Type</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Music Type</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Music Type</h5>
                        <div class="ibox-tools">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                            <a href="/admin/music-type/create" class="btn btn-primary btn-sm"><i class="fa fa-plus">
                                </i> Music type
                            </a>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Active</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/music-type/index",
                            columns: [
                                {
                                    data: "genreName",
                                    name: "genreName",
                                    searchable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "isActive",
                                    name: "isActive",
                                    searchable: false,
                                    render: function (data) {
                                        return data ? "Yes" : "No"
                                    }
                                },
                                {
                                    data: null,
                                    name: "Action",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        return (
                                            "<a href='/admin/music-type/edit/" +
                                            data.id +
                                            "' class='btn btn-primary btn-sm'><i class='fa fa-edit'></i></a> <a href='javascript:void(0)' id=" +
                                            data.id +
                                            " class='music_type_remove btn btn-danger btn-sm'><i class='fa fa-trash'></i></a>"
                                        );
                                    },
                                },
                            ],
                        });

                        $(document).on("click", ".music_type_remove", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/music-type/" + id;
                            deleteRecordByAjax(url, "Music Type", userTable);
                        });
                    });
                </script>