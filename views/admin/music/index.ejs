<% block('title', 'Music' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Music</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Music</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Music</h5>
                        <div class="ibox-tools">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                            <!-- <a href="/admin/music/create"><i class="fa fa-plus"></i> </a> -->
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width: 100%">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Uploaded By</th>
                                        <th>Genre Type</th>
                                        <th>Total Likes</th>
                                        <th>Total Comments</th>
                                        <th>Total Download</th>
                                        <th>Total Purchase</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay(
                    "<%= req.session.flash.type %>",
                    "<%= req.session.flash.message %>"
                );
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/music/index",
                            columnDefs: [{ width: '100px', targets: 3 }, { width: '100px', targets: 4 }, { width: '100px', targets: 5 }],
                            columns: [
                                {
                                    data: "title",
                                    name: "title",
                                    searchable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "userId",
                                    name: "Uploaded By",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        return (`<a href="/admin/user/show/${data.id}" class="href">${data.name}</a>`)
                                    }
                                },
                                {
                                    data: "musicTypeId.genreName",
                                    name: "Genre Type",
                                    sortable: false,
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "likeCount",
                                    name: "Total Likes",
                                    sortable: false,
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "commentCount",
                                    name: "Total Comments",
                                    sortable: false,
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "downloadCount",
                                    name: "Total Download",
                                    sortable: false,
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "purchaseCount",
                                    name: "Total Purchase",
                                    sortable: false,
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "isDeleted",
                                    name: "Deleted",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        return data ? "Deleted" : "-";
                                    },
                                },
                                {
                                    data: null,
                                    name: "Action",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        let actions = `
                                        <a href='/admin/music/show/${data.id}' class='btn btn-primary btn-sm'>
                                            <i class='fa fa-eye'></i>
                                        </a>
                                    `;

                                        if (!data.isDeleted) {
                                            actions += `
                                                <a href='/admin/music/edit/${data.id}' class='btn btn-info btn-sm'>
                                                    <i class='fa fa-edit'></i>
                                                </a>
                                            `;
                                        }

                                        return actions;
                                    },
                                },
                            ],
                        });

                        $(document).on("click", ".music_type_remove", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/music/" + id;
                            deleteRecordByAjax(url, "music", userTable);
                        });
                    });
                </script>