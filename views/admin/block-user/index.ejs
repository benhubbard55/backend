<% block('title', 'BlockUser' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Block-User</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>BlockUser</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Block User List</h5>
                        <div class="ibox-tools d-flex align-items-center gap-2 " style="gap: 10px;">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>BlockBy</th>
                                        <th>BlockTo</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/block-user/index",
                            columnDefs: [
                                { visible: false, targets: [0] }
                            ],
                            columns: [
                                {
                                    data: "id",
                                    name: "Id",
                                    searchable: false,
                                    sortable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "blockBy",
                                    name: "BlockBy",
                                    searchable: false,
                                    sortable: false,
                                    render: function (data) {
                                        if (data && data.id && data.name) {
                                            return `<a href="/admin/user/show/${data.id}" class="href">${data.name}</a>`;
                                        }
                                        return "N/A";
                                    }
                                },
                                {
                                    data: "blockTo",
                                    name: "BlockTo",
                                    searchable: false,
                                    sortable: false,
                                    render: function (data) {
                                        if (data && data.id && data.name) {
                                            return `<a href="/admin/user/show/${data.id}" class="href">${data.name}</a>`;
                                        }
                                        return "N/A";
                                    }
                                },
                            ],
                        });
                    });
                </script>