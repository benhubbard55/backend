<% block('title', 'Music Download History' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Music Download History</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Music Download History</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Music Download History</h5>
                        <div class="ibox-tools">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                            <!-- <a href="/admin/music/create"><i class="fa fa-plus"></i> </a> -->
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width: 100%">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Music Name</th>
                                        <th>Downloaded By</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay(
                    "<%= req.session.flash.type %>",
                    "<%= req.session.flash.message %>"
                );
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/music-download/index",
                            'columnDefs': [
                                { 'visible': false, 'targets': [0] }
                            ],
                            searching: false,
                            order: [[3, 'desc']],
                            columns: [
                                {
                                    data: "id",
                                    name: "Id",
                                    searchable: false,
                                    sortable: true,
                                },
                                {
                                    data: "musicId.title",
                                    name: "Music Name",
                                    searchable: false,
                                    sortable: false,
                                },
                                {
                                    data: "userId.name",
                                    name: "Downloaded By",
                                    searchable: false,
                                    sortable: false,
                                },
                                {
                                    data: "createdAt",
                                    name: "Time",
                                    sortable: true,
                                    searchable: true,
                                    render: function (data) {
                                        const utcDate = new Date(data);

                                        const date = new Date(utcDate.getTime() - utcDate.getTimezoneOffset() * 60000);
                                        const day = String(date.getDate()).padStart(2, '0');
                                        const month = String(date.getMonth() + 1).padStart(2, '0'); // Months are 0-based
                                        const year = date.getFullYear();

                                        const hours = String(date.getHours()).padStart(2, '0');
                                        const minutes = String(date.getMinutes()).padStart(2, '0');
                                        return `${day}/${month}/${year} ${hours}:${minutes}`;
                                    }
                                }
                            ],
                        });

                    });
                </script>