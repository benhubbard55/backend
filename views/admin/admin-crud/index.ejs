<% block('title', 'Admins' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Admins</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Admins</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Admin</h5>
                        <div class="ibox-tools">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                            <a href="/admin/create" class="btn btn-primary btn-sm">
                                <i class="fa fa-plus"></i> Admin
                            </a>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="adminDatatable" class="table table-striped table-bordered table-hover"
                                style="width:100%">
                                <thead>
                                    <tr>
                                        <!-- <th>Id</th> -->
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Email</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        //   console.log("$ found ", $);
                        var adminTable = $("#adminDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/index",
                            columns: [
                                {
                                    data: "firstName",
                                    name: "First Name",
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "lastName",
                                    name: "Last Name",
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "email",
                                    name: "Email",
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: null,
                                    name: "Action",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        if (data.id == 1) {
                                            return '-';
                                        } else {
                                            return (
                                                "<a href='/admin/edit/" +
                                                data.id +
                                                "' class='btn btn-primary btn-sm'><i class='fa fa-edit'></i></a> <a href='javascript:void(0)' id=" +
                                                data.id +
                                                " class='admin_remove btn btn-danger btn-sm'><i class='fa fa-trash'></i></a>"
                                            );
                                        }
                                    },
                                },
                            ],
                        });

                        $(document).on("click", ".admin_remove", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/" + id;
                            deleteRecordByAjax(url, "Admin", adminTable);
                        });
                    });
                </script>