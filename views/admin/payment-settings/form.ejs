<% if (record1 && record1.id) { %>
    <form id="form1" method="POST" action="/admin/payment-setting/update/<%= record1.id %>">
        <% } else { %>
            <form id="form1" method="POST" action="/admin/payment-setting/create">
                <% } %>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">Artist's Fees on Credit</label>
                        <div class="col-sm-2 input-group">
                            <input type="number" class="form-control" name="tax"
                                value="<% if (record1.tax >= 0) { %><%= record1.tax %><% } %>" />
                            <div class="input-group-append">
                                <span class="input-group-addon">%</span>
                            </div>
                            <input type="hidden" name="keyName" value="admin_commission">
                        </div>
                        <div class="col-sm-4 col-sm-offset-2">
                            <button class="btn btn-primary btn-sm" type="submit">
                                Save changes
                            </button>
                        </div>
                    </div>

                    <!-- <div class="hr-line-dashed"></div>
                    <div class="form-group row">
                        <div class="col-sm-4 col-sm-offset-2">
                            <button class="btn btn-primary btn-sm" type="submit">
                                Save changes
                            </button>
                        </div>
                    </div> -->
            </form>
    </form>

    <% if (record2 && record2.id) { %>
        <form id="form2" method="POST" action="/admin/payment-setting/update/<%= record2.id %>">
            <% } else { %>
                <form id="form2" method="POST" action="/admin/payment-setting/create">
                    <% } %>
                        <div class="form-group row">
                            <label class="col-sm-2 col-form-label">Customer Fees Per Transactions</label>
                            <div class="col-sm-2 input-group">
                                <input type="number" class="form-control" name="tax"
                                    value="<% if (record2.tax >= 0) { %><%= record2.tax %><% } %>" />
                                <div class="input-group-append">
                                    <span class="input-group-addon">%</span>
                                </div>
                                <input type="hidden" name="keyName" value="stripe_fees">
                            </div>
                            <div class="col-sm-4 col-sm-offset-2">
                                <button class="btn btn-primary btn-sm" type="submit">
                                    Save changes
                                </button>
                            </div>
                        </div>

                        <!-- <div class="hr-line-dashed"></div>
                        <div class="form-group row">
                            <div class="col-sm-4 col-sm-offset-2">
                                <button class="btn btn-primary btn-sm" type="submit">
                                    Save changes
                                </button>
                            </div>
                        </div> -->
                </form>

                <% if(req.session.flash) { %>
                    <script type="text/javascript">
                        $(document).ready(function () {
                            toastrDisplay(
                                "<%= req.session.flash.type %>",
                                "<%= req.session.flash.message %>"
                            );
                        });
                    </script>
                    <% req.session.flash={}; %>
                        <% }%>

                            <script>
                                $(document).ready(function () {
                                    var validator1 = $("#form1").validate({
                                        rules: {
                                            tax: { required: true, min: 0, max: 50 },
                                        },
                                        messages: {
                                            name: { required: "Name is required" },
                                        },
                                    });
                                    var validator2 = $("#form2").validate({
                                        rules: {
                                            tax: { required: true, min: 0, max: 50 },
                                        },
                                        messages: {
                                            name: { required: "Name is required" },
                                        },
                                    });
                                });
                            </script>
        </form>