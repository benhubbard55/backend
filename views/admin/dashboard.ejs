<% block('title', 'Dashboard' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Layouts</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item active">
                    <strong>Dashboard</strong>
                </li>
            </ol>
        </div>
    </div>

    <div class="wrapper wrapper-content">


        <div class="row mt-3">
            <div class="col-lg-3">
                <div class="ibox ">
                    <div class="ibox-title">
                        <!-- <span class="label label-success float-right">Monthly</span> -->
                        <h5>Admin</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">
                            <%= adminCount %>
                        </h1>
                        <!-- <div class="stat-percent font-bold text-success">98% <i class="fa fa-bolt"></i></div> -->
                        <!-- <small>Total income</small> -->
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="ibox ">
                    <div class="ibox-title">
                        <!-- <span class="label label-success float-right">Monthly</span> -->
                        <h5>Users</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">
                            <%= usersCount %>
                        </h1>
                        <!-- <div class="stat-percent font-bold text-success">98% <i class="fa fa-bolt"></i></div> -->
                        <!-- <small>Total income</small> -->
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="ibox ">
                    <div class="ibox-title">
                        <!-- <span class="label label-success float-right">Monthly</span> -->
                        <h5>Music Type</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">
                            <%= musicTypeCount %>
                        </h1>
                        <!-- <div class="stat-percent font-bold text-success">98% <i class="fa fa-bolt"></i></div> -->
                        <!-- <small>Total income</small> -->
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="ibox ">
                    <div class="ibox-title">
                        <!-- <span class="label label-success float-right">Monthly</span> -->
                        <h5>Musics</h5>
                    </div>
                    <div class="ibox-content">
                        <h1 class="no-margins">
                            <%= musicCount %>
                        </h1>
                        <!-- <div class="stat-percent font-bold text-success">98% <i class="fa fa-bolt"></i></div> -->
                        <!-- <small>Total income</small> -->
                    </div>
                </div>
            </div>
        </div>


        <div style="background-color: white;padding: 10px 10px 40px 10px; height: 400px;">
            <div class="row justify-content-between px-1">
                <div class="col-4 d-flex" style="margin-block: auto;gap: 20px;">
                    <div>
                        <div>Total Income</div>
                        <h1 id="actualIncome" style="margin-top: 0px;">$0</h1>
                    </div>
                    <div>
                        <div>Total Profit</div>
                        <h1 id="actualProfit" style="margin-top: 0px;">$0</h1>
                    </div>
                </div>
                <div class="col-2">
                    <select id="changeYear" class="form-control">
                    </select>
                </div>
            </div>

            <canvas class="mb-4" id="myChart"></canvas>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>


            const ctx = document.getElementById('myChart');
            let showChart = new Chart(ctx, {
                type: 'bar',

            });


            // get year list in revers order
            let minYear = 2024
            let maxYear = new Date().getFullYear() + 1
            const yearList = []
            const diff = maxYear - minYear
            for (let index = 0; index < diff; index++) {
                maxYear -= 1
                if (minYear <= maxYear) {
                    $("#changeYear").append(`
                    <option value="${maxYear}">${maxYear}</option>
                    `)
                }
            }
            $(document).ready(function () {
                getAnalyticsData("2024")

                $("#changeYear").change(function (e) {
                    getAnalyticsData(e.target.value)

                });
            });

            function getAnalyticsData(year) {
                // Destroy the old chart before creating a new one
                showChart.destroy();

                $.ajax({
                    type: "GET",
                    url: `/admin/dashboard/analytics?year=${year}`,
                    success: function (data, status, xhr) {
                        $("#actualIncome").empty()
                        $("#actualIncome").append(`$${data?.actualIncome}`)
                        $("#actualProfit").empty()
                        $("#actualProfit").append(`$${data?.actualProfit}`)

                        showChart = new Chart(ctx, {
                            type: 'bar',
                            data: {
                                labels: data?.monthList,
                                datasets: [{
                                    label: `Income $(${data?.totalIncomeYearly})`,
                                    data: data?.totalIncomeMonthly,
                                    borderWidth: 0.5,
                                    backgroundColor: ["#1ab394"],
                                }, {
                                    label: `Profit $(${data?.totalProfitYearly})`,
                                    data: data?.totalProfitMonthly,
                                    borderWidth: 0.5,
                                    backgroundColor: ["#2F4050"],
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: {
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                    },
                });
            }

        </script>

    </div>