<% block('title', 'Users' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Users</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Users</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Users</h5>
                        <div class="ibox-tools">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Mobile Number</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/user/index",
                            columns: [
                                {
                                    data: "name",
                                    name: "name",
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "email",
                                    name: "email",
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: null,
                                    name: null,
                                    searchable: false,
                                    sortable: false,
                                    render: function (data) {
                                        if (data.phoneNo) {
                                            return `${data.countryCode} ${data.phoneNo}`;
                                        }
                                        return '<i>Not Provided</i>';
                                    }
                                },
                                {
                                    data: null,
                                    name: null,
                                    searchable: false,
                                    sortable: false,
                                    render: function (data) {
                                        if (data.isDeleted) {
                                            return `<h4 class="text-danger">Account Deleted</h4>`
                                        }
                                        return `<div class="switch">
                                <div class="onoffswitch">
                                    <input type="checkbox" id=${data?.id} ${data?.isActive ? "checked" : ""} class="onoffswitch-checkbox changeStatus">
                                    <label class="onoffswitch-label" for=${data?.id}>
                                        <span class="onoffswitch-inner"></span>
                                        <span class="onoffswitch-switch"></span>
                                    </label>
                                </div>
                            </div>`;
                                    }
                                },
                                {
                                    data: null,
                                    name: "Action",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        if (data.isDeleted) {
                                            return `<h4 class="text-danger">Account Deleted</h4>`
                                        }
                                        return (
                                            "<a href='/admin/user/show/" + data.id + "' class='btn btn-primary btn-sm'><i class='fa fa-eye'></i></a>   <a href='/admin/user/edit/" + data.id + "' class='btn btn-info btn-sm'><i class='fa fa-edit'></i></i></a>"
                                        );
                                    },
                                },
                            ],
                        });

                        $(document).on("click", ".user_remove", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/user/" + id;
                            deleteRecordByAjax(url, "User", userTable);
                        });


                        $(document).on("change", ".changeStatus", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/user/status-change/" + id;
                            changeStatusRecordByAjax(url, "User", userTable);
                        });
                    });
                </script>