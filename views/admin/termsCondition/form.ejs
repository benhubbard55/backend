<% if (termRecord && termRecord.id) { %>
    <form id="termForm" method="POST" action="/admin/termsCondition/update/<%= termRecord.id %>">
        <% } else { %>
            <form id="termForm" method="POST" action="/admin/termsCondition/create" enctype="multipart/form-data">
                <% } %>
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">Description</label>
                        <div class="col-sm-10">
                            <!-- <input type="text" class="form-control" name="answer"
                                value="<% if (termRecord.answer) { %><%= termRecord.answer %><% } %>" /> -->
                            <textarea class="form-control" id="description"
                                name="description"><% if (termRecord.description) { %><%= termRecord.description %><% } %></textarea>
                        </div>
                    </div>

                    <div class="hr-line-dashed"></div>
                    <div class="form-group row">
                        <div class="col-sm-4 col-sm-offset-2">
                            <a href="/admin/terms" class="btn btn-white btn-sm">Cancel</a>
                            <button class="btn btn-primary btn-sm" type="submit">Save changes</button>
                        </div>
                    </div>
            </form>
            <% if(req.session.flash) { %>
                <script type="text/javascript">
                    $(document).ready(function () {
                        toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
                    });
                </script>
                <% req.session.flash={}; %>
                    <% }%>
                        <script src="https://cdn.ckeditor.com/4.16.2/standard/ckeditor.js"></script>

                        <script>
                            CKEDITOR.replace('description', {
                                removeButtons: '',
                                // extraPlugins: 'colorbutton,colordialog,justify,showblocks,font',                                                              
                                entities: false,  // Prevents CKEditor from converting tags into HTML entities
                                basicEntities: false, // Prevents conversion of special characters like `<`, `>`
                                allowedContent: true, // Allows all HTML content without filtering
                                extraAllowedContent: '*[*]{*}(*);', // Allows inline styles and attributes                                                                
                                enterMode: CKEDITOR.ENTER_BR,  // Pressing Enter adds `<br>` instead of `<p>`
                                shiftEnterMode: CKEDITOR.ENTER_P, // Shift+Enter adds `<p>`
                                autoParagraph: false
                            });

                        </script>

                        <script>
                            $(document).ready(function () {
                                var validator = $("#termForm").validate({
                                    rules: {
                                        description: { required: true }
                                    },
                                    messages: {
                                        description: { required: "Description is required" }
                                    },
                                });
                            });
                        </script>
    </form>