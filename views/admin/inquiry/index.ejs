<% block('title', 'Inquiries' ); %>
    <div class="row wrapper border-bottom white-bg page-heading">
        <div class="col-lg-10">
            <h2>Inquiries</h2>
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/admin/dashboard">Dashboard</a>
                </li>
                <li class="breadcrumb-item active">
                    <strong>Inquiries</strong>
                </li>
            </ol>
        </div>
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Inquiries</h5>
                        <div class="ibox-tools d-flex align-items-center gap-2 " style="gap: 10px;">
                            <a class="collapse-link">
                                <i class="fa fa-chevron-up"></i>
                            </a>
                        </div>
                    </div>

                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="userDatatable" class="table table-striped table-bordered table-hover"
                                style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Phone No.</th>
                                        <th>Message</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <% if(req.session.flash) { %>
        <script type="text/javascript">
            $(document).ready(function () {
                toastrDisplay("<%= req.session.flash.type %>", "<%= req.session.flash.message %>");
            });
        </script>
        <% req.session.flash={}; %>
            <% }%>

                <script type="text/javascript">
                    $(document).ready(function () {
                        var userTable = $("#userDatatable").DataTable({
                            processing: true,
                            serverSide: true,
                            responsive: true,
                            ajax: "/admin/inquiry/index",
                            columns: [
                                {
                                    data: "name",
                                    name: "name",
                                    searchable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "email",
                                    name: "email",
                                    searchable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "phoneNo",
                                    name: "phoneNo",
                                    searchable: false,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: "message",
                                    name: "message",
                                    searchable: true,
                                    defaultContent: "<i>Not Set</i>",
                                },
                                {
                                    data: null,
                                    name: "Action",
                                    sortable: false,
                                    searchable: false,
                                    render: function (data) {
                                        return (
                                            "<a href='javascript:void(0)' id=" +
                                            data.id +
                                            " class='inquiry_remove btn btn-danger btn-sm'><i class='fa fa-trash'></i></a>"
                                        );
                                    },
                                },
                            ],
                        });

                        $(document).on("click", ".inquiry_remove", function () {
                            var id = $(this).attr("id");
                            var url = "/admin/inquiry/" + id;
                            deleteRecordByAjax(url, "inquiry", userTable);
                        });
                    });
                </script>